# Auction Simulator Configuration
# Copy this file to .env and modify as needed:
#   cp example.env .env

# Number of bidders participating in each auction
NUM_BIDDERS=100

# Total number of auctions to run
NUM_AUCTIONS=40

# Timeout per auction (e.g., 500ms, 2s, 1m)
AUCTION_TIMEOUT=2s

# Maximum concurrent auctions (must be a whole number >= 1)
# Controls the semaphore size — limits how many auctions run at the same time
# Default: auto-detected from runtime.NumCPU()
MAX_CPUS=4

# Memory limit in MB for Go runtime (GOMEMLIMIT)
# Garbage collector runs more aggressively to stay within this limit
MAX_MEMORY_MB=512

# Output directory for auction result JSON files
RESULTS_DIR=results
